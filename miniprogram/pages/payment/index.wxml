<view class="page">
  <view class="payment-container" wx:if="{{payStatus === 'paying'}}">
    <view class="loading-icon">
      <view class="spinner"></view>
    </view>
    <text class="status-text">正在支付中...</text>
    <text class="order-info">订单编号：{{orderNo}}</text>
    <text class="price-info">支付金额：¥{{totalPrice}}</text>
  </view>

  <view class="payment-container success" wx:if="{{payStatus === 'success'}}">
    <view class="success-icon">
      <text>✓</text>
    </view>
    <text class="status-text success-text">支付成功</text>
    <text class="order-info">订单编号：{{orderNo}}</text>
    <text class="price-info">支付金额：¥{{totalPrice}}</text>
    
    <view class="countdown-tip">
      <text>{{countdown}}秒后自动跳转订单详情</text>
    </view>
    
    <view class="btn-group">
      <view class="btn primary" bindtap="onViewOrder">
        <text>查看订单</text>
      </view>
      <view class="btn" bindtap="onBackHome">
        <text>返回首页</text>
      </view>
    </view>
  </view>

  <view class="payment-container failed" wx:if="{{payStatus === 'failed'}}">
    <view class="failed-icon">
      <text>✕</text>
    </view>
    <text class="status-text failed-text">支付失败</text>
    <text class="order-info">订单编号：{{orderNo}}</text>
    
    <view class="btn-group">
      <view class="btn primary" bindtap="startPayment">
        <text>重新支付</text>
      </view>
      <view class="btn" bindtap="onBackHome">
        <text>返回首页</text>
      </view>
    </view>
  </view>
</view>
