<view class="page">
  <view class="header">
    <view class="avatar-wrap" wx:if="{{!userInfo}}">
      <button class="avatar-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <text>?</text>
      </button>
    </view>
    <view class="avatar" wx:else>
      <image src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    </view>
    <text class="nickname">{{userInfo.nickName || '微信用户'}}</text>
    <text class="login-tip" wx:if="{{!userInfo}}">点击头像登录</text>
  </view>

  <view class="section">
    <view class="section-header">
      <text class="section-title">我的资产</text>
    </view>
    <view class="assets-list">
      <view class="asset-item" wx:for="{{assets}}" wx:key="name" bindtap="onAssetTap" data-index="{{index}}">
        <text class="asset-value">{{item.value}}</text>
        <text class="asset-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section menu-section">
    <view class="menu-item" wx:for="{{menuList}}" wx:key="name" bindtap="onMenuTap" data-index="{{index}}">
      <text class="menu-name">{{item.name}}</text>
      <text class="menu-arrow">></text>
    </view>
  </view>
</view>
