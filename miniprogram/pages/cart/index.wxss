.page {
  min-height: 100vh;
  background-color: #F5F3EE;
  padding-bottom: 200rpx;
}

.cart-list {
  padding: 20rpx 30rpx;
}

.cart-item {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.item-img {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.item-img image {
  width: 100%;
  height: 100%;
}

.img-placeholder {
  width: 100%;
  height: 100%;
  background-color: #F5F5F5;
  display: flex;
  align-items: center;
  justify-content: center;
}

.img-placeholder text {
  font-size: 24rpx;
  color: #999999;
}

.item-info {
  flex: 1;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 10rpx;
}

.item-specs {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: auto;
}

.item-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D5678;
}

.quantity-control {
  display: flex;
  align-items: center;
}

.quantity-btn {
  width: 48rpx;
  height: 48rpx;
  background-color: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.quantity-btn text {
  font-size: 24rpx;
  color: #666666;
}

.quantity-btn.active {
  background-color: #2D5678;
}

.quantity-btn.active text {
  color: #FFFFFF;
}

.quantity-num {
  width: 60rpx;
  height: 48rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 10rpx;
}

.quantity-num text {
  font-size: 24rpx;
  color: #333333;
}

.order-info {
  background-color: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #333333;
}

.info-value {
  font-size: 28rpx;
  color: #333333;
}

.info-options {
  display: flex;
}

.option-btn {
  padding: 10rpx 30rpx;
  background-color: #F5F5F5;
  border-radius: 30rpx;
  margin-left: 20rpx;
}

.option-btn text {
  font-size: 26rpx;
  color: #666666;
}

.option-btn.active {
  background-color: #2D5678;
}

.option-btn.active text {
  color: #FFFFFF;
}

.remark-input {
  flex: 1;
  text-align: right;
  font-size: 26rpx;
  color: #999999;
}

.submit-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.price-info {
  margin-bottom: 20rpx;
}

.price-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.price-label {
  font-size: 26rpx;
  color: #666666;
}

.price-value {
  font-size: 26rpx;
  color: #333333;
}

.price-value.discount {
  color: #E53935;
}

.total-row {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #EEEEEE;
}

.total-label {
  font-weight: 600;
  color: #333333;
}

.total-value {
  font-weight: 700;
  color: #E53935;
  font-size: 30rpx;
}

.coupon-item {
  cursor: pointer;
}

.coupon-value {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.coupon-name {
  font-size: 26rpx;
  color: #E53935;
  font-weight: 500;
}

.coupon-placeholder {
  font-size: 26rpx;
  color: #999999;
}

.coupon-arrow {
  font-size: 24rpx;
  color: #CCCCCC;
}

.submit-btn {
  background-color: #2D5678;
  border-radius: 50rpx;
  padding: 24rpx;
  text-align: center;
}

.submit-btn.disabled {
  background-color: #cccccc;
  pointer-events: none;
}

.submit-btn text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 500;
}
