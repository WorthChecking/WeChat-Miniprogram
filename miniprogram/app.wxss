page {
  background-color: #F5F3EE;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.container {
  padding: 20rpx;
}

.primary-color {
  color: #2D5678;
}

.primary-bg {
  background-color: #2D5678;
}

.text-gray {
  color: #666666;
}

.text-brown {
  color: #333333;
}

.text-light-brown {
  color: #666666;
}

.bg-white {
  background-color: #FFFFFF;
}

.bg-cream {
  background-color: #F5F3EE;
}

.bg-light-orange {
  background-color: #EBE4D3;
}

.card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  background-color: #2D5678;
  color: #FFFFFF;
  border-radius: 40rpx;
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary:active {
  background-color: #1E3D54;
}

.btn-outline {
  background-color: #FFFFFF;
  color: #2D5678;
  border: 2rpx solid #2D5678;
  border-radius: 40rpx;
  padding: 18rpx 38rpx;
  text-align: center;
  font-size: 28rpx;
}

.btn-outline:active {
  background-color: #F0EDE5;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.flex-center {
  display: flex;
  justify-content: center;
  align-items: center;
}

.flex-1 {
  flex: 1;
}

.price {
  color: #2D5678;
  font-weight: 600;
  font-size: 32rpx;
}

.price-large {
  color: #2D5678;
  font-weight: 600;
  font-size: 40rpx;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.tag-orange {
  background-color: #F0EDE5;
  color: #2D5678;
}

.tag-gray {
  background-color: #F5F5F5;
  color: #666666;
}

.divider {
  height: 1rpx;
  background-color: #EEEEEE;
  margin: 20rpx 0;
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.cart-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx 0;
}
